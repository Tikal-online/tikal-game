{
  "KeyVaultName": "tikal-identity-keyvault",
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Token": {
    "Issuer": "https://auth.tikalonline.com",
    "Audience": "https://tikalonline.com",
    "AccessTokenExpiration": 300,
    "RefreshTokenExpiration": 3600
  },
  "OTEL_EXPORTER_OTLP_ENDPOINT": "https://otel.tikalonline.com",
  "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
  "OTEL_SERVICE_NAME": "Identity"
}
