{
  "name": "Tikal",
  "image": "mcr.microsoft.com/devcontainers/dotnet:latest",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/git-lfs:1": {},
    "ghcr.io/microsoft/aspire-devcontainer-feature/aspire:2": {},
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/node:2.0.0": {
      "version": "24"
    },
    "ghcr.io/devcontainers-extra/features/mise:1": {},
    "ghcr.io/riccardobravin/devcontainer-features/zensical:0": {}
  },
  "runArgs": [
    "--network=host"
  ],
  "mounts": [
    "source=usersecrets,target=/home/vscode/.microsoft/usersecrets,type=volume",
    "source=${localEnv:HOME}/.aspnet/dev-certs,target=/.aspnet/dev-certs/trust,type=bind,consistency=cached"
  ],
  "remoteEnv": {
    "SSL_CERT_DIR": "/usr/lib/ssl/certs:/home/vscode/.aspnet/dev-certs/trust"
  },
  "postStartCommand": "./.devcontainer/init_devcontainer.sh",
  "remoteUser": "vscode"
}
